# ─────────────────────────────────────────────────────────────────────────────
# Connect-a-roadmap step 3 (ARCHITECTURE.md §4).
# Copy this into a ROADMAP repo as: .github/workflows/notify-site.yml
# It pings the proofstone site to rebuild whenever this roadmap's README or
# assets change — so a content edit lands on the site with no manual steps.
#
# One-time setup: add a secret PROOFSTONE_DISPATCH_TOKEN to this repo (or the org)
# = a fine-grained PAT scoped to the SITE repo with "Contents: read & write"
# (the scope GitHub requires to POST repository_dispatch). Nothing else needed.
#
# Set OWNER/SITE_REPO below to the site repo created in Ф3 (recommended:
# proofstone/proofstone.dev).
# ─────────────────────────────────────────────────────────────────────────────
name: notify-site

on:
  push:
    branches: [main]
    paths:
      - 'README.md'
      - 'assets/**'

jobs:
  dispatch:
    runs-on: ubuntu-latest
    steps:
      - name: Tell the proofstone site to rebuild
        run: |
          curl -sf -X POST \
            -H "Accept: application/vnd.github+json" \
            -H "Authorization: Bearer ${{ secrets.PROOFSTONE_DISPATCH_TOKEN }}" \
            "https://api.github.com/repos/proofstone/proofstone.dev/dispatches" \
            -d '{"event_type":"roadmap-content"}'
