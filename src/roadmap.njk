---
layout: base.njk
pagination:
  data: liveRoadmaps
  size: 1
  alias: roadmap
permalink: "/{{ roadmap.slug }}/"
pageType: roadmap
eleventyComputed:
  title: "{{ roadmap.title }} — proofstone"
  description: "{{ roadmap.tagline }}"
---
<div class="roadmap__bar">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">proofstone</a> <span aria-hidden="true">/</span> <span>{{ roadmap.title }}</span>
  </nav>
  <div class="roadmap__actions">
    <a class="btn btn--primary" href="https://github.com/{{ roadmap.repo }}" rel="noopener">★ Star on GitHub</a>
    <a class="btn" href="https://github.com/{{ roadmap.repo }}/edit/{{ roadmap.branch }}/README.md" rel="noopener">Edit</a>
    <a class="btn" href="https://github.com/{{ roadmap.repo }}/blob/{{ roadmap.branch }}/README.md" rel="noopener">View source</a>
  </div>
</div>

<div class="roadmap-layout">
  <aside class="toc" aria-label="Sections">
    <details class="toc__details" open>
      <summary class="toc__summary">Sections</summary>
      <ol class="toc__list">
        {%- for s in roadmap | roadmapToc %}
        <li class="toc__item">
          <a class="toc__link" href="#{{ s.id }}" data-toc="{{ s.id }}">
            <span class="toc__num">§{{ s.num }}</span>
            <span class="toc__title">{{ s.title }}</span>
            {%- if s.milestones.length %}
            <span class="toc__count" data-toc-total="{{ s.milestones.length }}" data-toc-ms="{{ s.milestones | join(',') }}">{{ s.milestones.length }}</span>
            {%- endif %}
          </a>
        </li>
        {%- endfor %}
      </ol>
    </details>
  </aside>

  <div class="roadmap-main">
    <article class="roadmap prose">
      {{ roadmap.content | roadmapMarkdown(roadmap) | safe }}
    </article>
  </div>
</div>
