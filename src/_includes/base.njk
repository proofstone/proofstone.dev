<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or (site.name + " — engineering roadmaps") }}</title>
  {#- Search snippets clamp around 155 chars; social cards are roomier. Only the
      SERP description is shortened, so the card keeps the full thesis line. #}
  <meta name="description" content="{{ metaDescription or description or site.tagline }}">
  {#- The error page is not a page: it must never claim canonical status (every
      real 404 response is served with this body, so a self-canonical here points
      crawlers at an indexable 200 URL) and its noindex must not depend on the
      pre-launch flag, or launch day turns it into an indexable soft-404. #}
  {%- set isErrorPage = page.url == "/404.html" %}
  {%- if not isErrorPage %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  {%- endif %}
  {% if site.noindex or isErrorPage %}<meta name="robots" content="noindex, nofollow">{% endif %}

  {%- set ogSlug = roadmap.slug if roadmap else "default" %}
  {%- set ogImage = site.url + "/assets/og/" + ogSlug + ".png" %}
  <meta property="og:type" content="{{ "article" if roadmap else "website" }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{{ title or (site.name + " — engineering roadmaps") }}">
  <meta property="og:description" content="{{ description or site.tagline }}">
  {%- if not isErrorPage %}
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  {%- endif %}
  {%- if roadmap.updated %}
  <meta property="article:modified_time" content="{{ roadmap.updated }}">
  {%- endif %}
  <meta property="og:image" content="{{ ogImage }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {%- set ogAlt = (roadmap.title if roadmap else site.name) + " — " + site.tagline %}
  <meta property="og:image:alt" content="{{ ogAlt }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or (site.name + " — engineering roadmaps") }}">
  <meta name="twitter:description" content="{{ description or site.tagline }}">
  <meta name="twitter:image" content="{{ ogImage }}">
  <meta name="twitter:image:alt" content="{{ ogAlt }}">

  {%- set sd = { pageType: pageType, roadmap: roadmap, site: site, pageUrl: page.url } | structuredData %}
  {%- if sd %}
  <script type="application/ld+json">{{ sd | jsonLd | safe }}</script>
  {%- endif %}

  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/assets/favicon-32.png" sizes="32x32" type="image/png">
  <link rel="apple-touch-icon" href="/assets/favicon-180.png">
  <link rel="stylesheet" href="/assets/styles.css">
  <script>
    // Set theme before paint to avoid a flash. Honors saved choice, else OS.
    (function () {
      try {
        var t = localStorage.getItem('proofstone:theme');
        if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    })();
  </script>
</head>
<body data-page="{{ pageType or 'page' }}"{% if roadmap %} data-roadmap="{{ roadmap.slug }}"{% endif %}>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-header">
    {#- Mark + wordmark lockup. The SVG is inlined (≈300 bytes, saves a request)
        and carries the same chiseled-P as the favicon/OG/avatar so the identity
        is one object everywhere. aria-hidden + the link's aria-label keep it a
        single named landmark, not a second focus target announcing nothing. #}
    <a class="brand" href="/" aria-label="proofstone — home">
      <svg class="brand__mark" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
        <rect width="32" height="32" rx="7" fill="#16223b"/>
        <path fill="#6f9bff" fill-rule="evenodd" d="M8.5 9.3L10.3 7.5L21.7 7.5L23.5 9.3L23.5 15.7L21.7 17.5L13.5 17.5L13.5 22.8L11.7 24.5L10.3 24.5L8.5 22.8Z M13.5 10.6L20 10.6L21.3 11.9L21.3 13.1L20 14.4L13.5 14.4Z"/>
      </svg>
      <span class="brand__word">proof<span>stone</span></span>
    </a>
    {#- Labelled because a roadmap page carries four other navigation landmarks
        (breadcrumb, section outline, roadmap map, the rest of the series); an
        unnamed one is the confusing entry in a landmark list. #}
    <nav class="site-nav" aria-label="Main">
      <a href="{{ site.org }}" rel="noopener">GitHub</a>
      {#- Named for the state it reports, not for the act: app.js maintains
          aria-pressed on it, so it announces "Dark theme, pressed" / "not
          pressed". The name must then stay static or the two contradict. #}
      <button type="button" class="theme-toggle" aria-label="Dark theme" title="Toggle theme">
        <span class="theme-toggle__icon" aria-hidden="true"></span>
      </button>
    </nav>
  </header>

  {#- tabindex="-1" is what makes "Skip to content" actually move focus: without
      it the browser sets the hash and leaves focus on <body>, so a screen
      reader's cursor never travels. Chromium's tab order compensates; Safari and
      several AT pairings do not. #}
  <main id="main" tabindex="-1">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>{{ site.name }} — engineering roadmaps. Static site. No tracking, no cookies.</p>
    <p>
      Content licensed per each roadmap's repository ·
      <a href="{{ site.org }}" rel="noopener">github.com/proofstone</a>
    </p>
  </footer>

  <script src="/assets/app.js" defer></script>
</body>
</html>
